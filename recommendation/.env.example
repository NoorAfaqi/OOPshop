# MySQL (same names as Node backend; optional MYSQL_* aliases in app)
DB_HOST=your-mysql-host
DB_PORT=3306
DB_USER=root
DB_PASSWORD=secret
DB_NAME=oopshop

# Supabase Postgres — Project Settings → Database
# On Render / Fly / many hosts: avoid "Direct connection" (db.*.supabase.co:5432) — it often
# resolves to IPv6 and fails with "Network is unreachable". Use "Connection pooling" instead
# (pooler host, port 6543). Append ?sslmode=require
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require

# Embedding model (FastEmbed / ONNX; free, local)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384
