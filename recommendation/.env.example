# MySQL (same names as Node backend; optional MYSQL_* aliases in app)
DB_HOST=your-mysql-host
DB_PORT=3306
DB_USER=root
DB_PASSWORD=secret
DB_NAME=oopshop

# Supabase Postgres — Project Settings → Database → Connection string (URI)
# Pooler often uses port 6543. Append ?sslmode=require if the client does not default to SSL.
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require

# Embedding model (FastEmbed / ONNX; free, local)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384
