{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "builds": [
    {
      "src": "main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "main.py"
    }
  ],
  "functions": {
    "main.py": {
      "maxDuration": 60,
      "memory": 3008,
      "excludeFiles": "{**/__pycache__/**,**/*.pyc,.venv/**,.idea/**,**/.env,**/.env.*}"
    }
  }
}