# Copy to .env and adjust. See repo root .env for full stack.

DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=oopshop
JWT_SECRET=change-me-min-32-chars-for-production-use-long-secret

# Optional: override default recommendation API (FastAPI on Render)
# RECOMMENDATION_API_URL=https://oopshop-recommendation.onrender.com
# RECOMMENDATION_API_TIMEOUT_MS=120000
# POST /embeddings/sync after product create/delete (background); long-running on Render
# RECOMMENDATION_SYNC_TIMEOUT_MS=600000
# RECOMMENDATION_SYNC_ENABLED=true
