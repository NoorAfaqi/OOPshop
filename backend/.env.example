# Copy to .env and adjust. See repo root .env for full stack.

DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=oopshop
JWT_SECRET=change-me-min-32-chars-for-production-use-long-secret

# --- Transactional email (Nodemailer) — order placed & shipped ---
# Without these variables, checkout/shipping still work but emails are skipped (logged as warning).
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-account@gmail.com
# SMTP_PASSWORD=your-app-password
# EMAIL_FROM=your-account@gmail.com
# EMAIL_FROM_NAME=OOPshop
# Optional: link button in HTML emails (shop / web app URL)
# FRONTEND_URL=https://your-shop.example.com
# Symbol shown in order emails (default €)
# ORDER_EMAIL_CURRENCY_SYMBOL=€

# Optional: override default recommendation API (FastAPI on Render)
# RECOMMENDATION_API_URL=https://oopshop-recommendation.onrender.com
# RECOMMENDATION_API_TIMEOUT_MS=120000
# POST /embeddings/sync after product create/delete (background); long-running on Render
# RECOMMENDATION_SYNC_TIMEOUT_MS=600000
# RECOMMENDATION_SYNC_ENABLED=true
