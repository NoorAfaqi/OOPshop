# Root level ignores

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# Logs
*.log
logs/
backend/logs/
frontend/.next/

# Environment / secrets — any .env-style file anywhere in the repo
.env
.env.*
**/.env
**/.env.*
*.env

# Allow committing env templates (un-ignore must come after ignore rules above)
!.env.example
!.env.sample
!.env.template
!.env.*.example

# Dependencies
node_modules/
backend/node_modules/
frontend/node_modules/

# Build outputs
dist/
build/
.next/
out/
backend/dist/
frontend/.next/
frontend/out/

# Temporary files
*.tmp
*.temp
*.cache

# Docker
.dockerignore

# Testing
coverage/
.nyc_output/
*.lcov

# Package manager locks (optional - uncomment if you want to ignore)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# Database
*.sqlite
*.db

# Misc
*.pid
*.seed
*.pid.lock